Options -Indexes

# ── Block direct access to sensitive directories ──────────────────────────────
# RewriteRule-based blocks work in .htaccess (unlike <DirectoryMatch>).
# Applies whether the CMS runs at the domain root or in a subfolder.
RewriteEngine On

# Block app/, config/, data/, cache/, content/ directories
RewriteRule (^|/)(?:app|config|data|cache|content)(/|$) - [F,L]

# Block theme template directories — assets are public, templates are not
RewriteRule (^|/)themes/[^/]+/templates(/|$) - [F,L]

# Block dotfiles (e.g. .htaccess itself if someone guesses the path)
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block spec / markdown / config files
<FilesMatch "\.(md|sql|sh|lock|yaml|yml)$">
    Require all denied
</FilesMatch>

# ── Front controller ──────────────────────────────────────────────────────────
# Serve existing files and directories directly (assets/, admin/ PHP files, etc.)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything else through the front controller
RewriteRule ^ index.php [QSA,L]
